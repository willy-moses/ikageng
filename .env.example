# ─────────────────────────────────────────────────────────────────────────────
# Ikageng Waiting List — Environment Variables
# Copy this file to .env.local for local dev, then add these in Vercel dashboard
# ─────────────────────────────────────────────────────────────────────────────

# ── Simple admin password (shown on login screen) ─────────────────────────────
ADMIN_PASSWORD=your-secret-password-here

# ── Azure App Registration (for Microsoft Graph API access to OneDrive) ───────
# Create at: https://portal.azure.com → Azure Active Directory → App registrations
# Required API permissions: Files.ReadWrite (Application permission)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── OneDrive / Excel file details ─────────────────────────────────────────────
# ONEDRIVE_USER_ID: the email or object ID of the OneDrive owner
#   e.g. admin@yourorg.onmicrosoft.com
ONEDRIVE_USER_ID=your-email@yourdomain.com

# EXCEL_FILE_ID: the Drive item ID of your .xlsx file
#   Find it: Graph Explorer → GET https://graph.microsoft.com/v1.0/me/drive/root/children
#   or open the file in OneDrive, click Share → Copy link, the ID is in the URL
EXCEL_FILE_ID=your-excel-file-drive-item-id

# EXCEL_SHEET_NAME: the name of your Excel worksheet OR Table object
#   Default: Workers
EXCEL_SHEET_NAME=Workers
